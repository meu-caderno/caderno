{
  "name": "@meu-caderno/src",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    ".",
    "pkgs/apps/pwa",
    "pkgs/core"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "nx": "23.0.1"
  },
  "scripts": {
    "format:check": "nx run @meu-caderno/src:format:check",
    "format:fix": "nx run @meu-caderno/src:format:fix",
    "lint:check": "nx run @meu-caderno/src:lint:check",
    "lint:fix": "nx run @meu-caderno/src:lint:fix",
    "quality:check": "nx run @meu-caderno/src:quality:check",
    "quality:check:ci": "nx run @meu-caderno/src:quality:check:ci",
    "quality:fix": "nx run @meu-caderno/src:quality:fix",
    "all:build": "nx run @meu-caderno/src:all:build",
    "all:typecheck": "nx run @meu-caderno/src:all:typecheck",
    "all:test": "nx run @meu-caderno/src:all:test",
    "all:coverage": "nx run @meu-caderno/src:all:coverage",
    "all:e2e": "nx run @meu-caderno/src:all:e2e"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "format:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome format --fix ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "format:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome format ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "lint:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "lint:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check --fix ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:check:ci": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome ci ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check --fix --unsafe ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "all:build": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": true,
          "commands": [
            "nx run @meu-caderno/apps.pwa:build"
          ]
        }
      },
      "all:typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": true,
          "commands": [
            "nx run @meu-caderno/apps.pwa:typecheck",
            "nx run @meu-caderno/core:typecheck"
          ]
        }
      },
      "all:test": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": true,
          "commands": [
            "nx run @meu-caderno/apps.pwa:test",
            "nx run @meu-caderno/core:test"
          ]
        }
      },
      "all:coverage": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": true,
          "commands": [
            "nx run @meu-caderno/apps.pwa:coverage",
            "nx run @meu-caderno/core:coverage"
          ]
        }
      },
      "all:e2e": {
        "executor": "nx:run-commands",
        "options": {
          "parallel": false,
          "commands": [
            "nx run @meu-caderno/apps.pwa:e2e"
          ]
        }
      }
    }
  }
}
