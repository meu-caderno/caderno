{
  "name": "@meu-caderno/src",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    ".",
    "pkgs/apps/pwa",
    "pkgs/core",
    "pkgs/validation",
    "pkgs/adapters/platform-browser",
    "pkgs/adapters/persistence-dexie",
    "pkgs/adapters/crypto"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "nx": "23.0.0"
  },
  "scripts": {
    "format:check": "nx run @meu-caderno/src:format:check",
    "format:fix": "nx run @meu-caderno/src:format:fix",
    "lint:check": "nx run @meu-caderno/src:lint:check",
    "lint:fix": "nx run @meu-caderno/src:lint:fix",
    "quality:check": "nx run @meu-caderno/src:quality:check",
    "quality:check:ci": "nx run @meu-caderno/src:quality:check:ci",
    "quality:fix": "nx run @meu-caderno/src:quality:fix",
    "all:build": "nx run @meu-caderno/src:all:build",
    "all:typecheck": "nx run @meu-caderno/src:all:typecheck",
    "all:test": "nx run @meu-caderno/src:all:test",
    "all:coverage": "nx run @meu-caderno/src:all:coverage",
    "all:e2e": "nx run @meu-caderno/src:all:e2e"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "format:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome format --fix ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "format:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome format ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "lint:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "lint:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check --fix ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:check": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:check:ci": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome ci ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "quality:fix": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "biome check --fix --unsafe ."
          ],
          "parallel": false
        },
        "cache": false,
        "continuous": false
      },
      "all:build": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx run-many -t build"
          ]
        }
      },
      "all:typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx run-many -t typecheck"
          ]
        }
      },
      "all:test": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx run-many -t test"
          ]
        }
      },
      "all:coverage": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx run-many -t coverage"
          ]
        }
      },
      "all:e2e": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx run-many -t e2e"
          ]
        }
      }
    }
  }
}
