{
  "name": "@meu-caderno/apps.pwa",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nx run build",
    "dev": "nx run dev",
    "generate": "nx run generate",
    "preview": "nx run preview",
    "prepare": "nx run prepare",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "cleanup": "rm -rf .nuxt .output dist"
  },
  "dependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/hints": "1.1.3",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "1.2.1",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/i18n": "10.4.0",
    "@tanstack/vue-query": "^5.101.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@unhead/vue": "^2.0.3 || ^3.0.0",
    "@vite-pwa/nuxt": "1.1.1",
    "@vueuse/nuxt": "14.3.0",
    "date-fns": "^4.4.0",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "nx": {
    "includedScripts": [],
    "namedInputs": {
      "default": [
        "{projectRoot}/app",
        "{projectRoot}/public",
        "{projectRoot}/nuxt.config.ts",
        "{projectRoot}/tsconfig.json"
      ]
    },
    "targets": {
      "build": {
        "inputs": [
          "default"
        ],
        "outputs": [
          "{projectRoot}/.output"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt build"
          ],
          "parallel": false
        },
        "dependsOn": [
          "prepare"
        ],
        "cache": true,
        "continuous": false
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt dev"
          ],
          "parallel": false
        },
        "continuous": true
      },
      "generate": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt generate"
          ],
          "parallel": false
        },
        "dependsOn": [
          "prepare"
        ]
      },
      "preview": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt preview"
          ],
          "parallel": false
        },
        "continuous": true
      },
      "prepare": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt prepare"
          ],
          "parallel": false
        },
        "continuous": false,
        "cache": false
      }
    }
  }
}
