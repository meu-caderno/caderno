{
  "name": "@meu-caderno/apps.pwa",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nx run build",
    "dev": "nx run dev",
    "generate": "nx run generate",
    "preview": "nx run preview",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.101.0",
    "@vite-pwa/nuxt": "1.1.1",
    "date-fns": "^4.4.0",
    "nuxt": "^4.4.8",
    "reka-ui": "^2.10.0",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "nx": {
    "includedScripts": [],
    "namedInputs": {
      "default": [
        "{projectRoot}/app",
        "{projectRoot}/public",
        "{projectRoot}/nuxt.config.ts",
        "{projectRoot}/tsconfig.json"
      ]
    },
    "targets": {
      "build": {
        "inputs": [
          "default"
        ],
        "outputs": [
          "{projectRoot}/.output",
          "{projectRoot}/.nuxt"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt build"
          ],
          "parallel": false
        },
        "cache": true
      },
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt dev"
          ],
          "parallel": false
        },
        "continuos": true
      },
      "generate": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt generate"
          ],
          "parallel": false
        }
      },
      "preview": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "nuxt preview"
          ],
          "parallel": false
        }
      }
    }
  }
}