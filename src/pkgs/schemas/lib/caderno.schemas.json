{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "caderno.schemas.json",
    "$defs": {
        "Id": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Id.json",
            "type": "string",
            "format": "uuid",
            "description": "Stable identifier."
        },
        "DateIso": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "DateIso.json",
            "type": "string",
            "format": "date",
            "description": "Simple date, without hour (ISO YYYY-MM-DD)."
        },
        "Instant": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Instant.json",
            "type": "string",
            "format": "date-time",
            "description": "Instant."
        },
        "Color": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Color.json",
            "type": "string",
            "description": "Color representation."
        },
        "Score": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Score.json",
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Score from 0 to 100."
        }
    }
}