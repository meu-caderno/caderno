{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "schemas.json",
    "$defs": {
        "Modules": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Modules.json",
            "type": "object",
            "properties": {
                "absences": {
                    "type": "boolean"
                },
                "grades": {
                    "type": "boolean"
                },
                "term": {
                    "type": "boolean"
                },
                "streak": {
                    "type": "boolean"
                },
                "hours": {
                    "type": "boolean"
                },
                "examNotice": {
                    "type": "boolean"
                },
                "certificate": {
                    "type": "boolean"
                }
            },
            "required": [
                "absences",
                "grades",
                "term",
                "streak",
                "hours",
                "examNotice",
                "certificate"
            ],
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "Vocabulary": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Vocabulary.json",
            "type": "object",
            "properties": {
                "subject": {
                    "type": "string"
                },
                "activity": {
                    "type": "string"
                },
                "attendance": {
                    "type": "string"
                },
                "term": {
                    "type": "string"
                }
            },
            "required": [
                "subject",
                "activity",
                "attendance",
                "term"
            ],
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "BackendRef": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "BackendRef.json",
            "type": "object",
            "properties": {
                "backend": {
                    "type": "string"
                },
                "hostId": {
                    "$ref": "Id.json"
                }
            },
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "Id": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Id.json",
            "type": "string",
            "format": "uuid",
            "description": "Stable identifier."
        },
        "AcademicTerm": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "AcademicTerm.json",
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "Id.json"
                },
                "label": {
                    "type": "string"
                },
                "start": {
                    "$ref": "DateIso.json"
                },
                "end": {
                    "$ref": "DateIso.json"
                }
            },
            "required": [
                "id",
                "label"
            ],
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "DateIso": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "DateIso.json",
            "type": "string",
            "format": "date",
            "description": "Simple date, without hour (ISO YYYY-MM-DD)."
        },
        "Bucket": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Bucket.json",
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "Id.json"
                },
                "name": {
                    "type": "string"
                },
                "icon": {
                    "type": "string"
                },
                "completed": {
                    "type": "integer",
                    "minimum": -2147483648,
                    "maximum": 2147483647
                },
                "target": {
                    "type": "integer",
                    "minimum": -2147483648,
                    "maximum": 2147483647
                },
                "unit": {
                    "type": "string"
                }
            },
            "required": [
                "id",
                "name",
                "completed",
                "target"
            ],
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "Context": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Context.json",
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "Id.json"
                },
                "name": {
                    "type": "string"
                },
                "goal": {
                    "$ref": "Goal.json"
                },
                "modules": {
                    "$ref": "Modules.json"
                },
                "membership": {
                    "$ref": "MembershipType.json"
                },
                "absencePolicy": {
                    "$ref": "AbsencePolicy.json"
                },
                "buckets": {
                    "type": "array",
                    "items": {
                        "$ref": "Bucket.json"
                    }
                },
                "vocabulary": {
                    "$ref": "Vocabulary.json"
                },
                "terms": {
                    "type": "array",
                    "items": {
                        "$ref": "AcademicTerm.json"
                    }
                },
                "minimumAttendance": {
                    "type": "number"
                },
                "minimumGrade": {
                    "$ref": "Score.json"
                },
                "social": {
                    "$ref": "BackendRef.json"
                }
            },
            "required": [
                "id",
                "name",
                "goal",
                "modules",
                "membership",
                "absencePolicy"
            ],
            "unevaluatedProperties": {
                "not": {}
            }
        },
        "Goal": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Goal.json",
            "type": "string",
            "enum": [
                "NA",
                "COLLEGE",
                "COLLEGE_EXAM",
                "CIVIL_SERVICE_EXAM",
                "FREE_COURSE",
                "FREE"
            ]
        },
        "MembershipType": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "MembershipType.json",
            "type": "string",
            "enum": [
                "PERSONAL",
                "CLASS",
                "GROUP"
            ]
        },
        "AbsencePolicy": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "AbsencePolicy.json",
            "type": "string",
            "enum": [
                "NONE",
                "PLAN",
                "ATTENDANCE_FOCUSED"
            ]
        },
        "Score": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Score.json",
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Score from 0 to 100."
        },
        "Instant": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Instant.json",
            "type": "string",
            "format": "date-time",
            "description": "Instant."
        },
        "Color": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": "Color.json",
            "type": "string",
            "description": "Color representation."
        }
    }
}