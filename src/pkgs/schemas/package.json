{
  "name": "@meu-caderno/caderno.schemas",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@typespec/compiler": "^1.13.0",
    "@typespec/json-schema": "^1.13.0"
  },
  "scripts": {
    "build": "nx build"
  },
  "nx": {
    "includedScripts": [],
    "namedInputs": {
      "default": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tspconfig.yaml"
      ]
    },
    "targets": {
      "build": {
        "inputs": [
          "default"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "tsp compile src/main.tsp --output-dir ./dist"
        },
        "cache": true
      }
    }
  }
}