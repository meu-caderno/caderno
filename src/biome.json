{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!**/.nx/*",
      "!**/.nuxt/*",
      "!**/.output/*",
      "!**/coverage/*",
      "!**/playwright-report/*",
      "!**/test-results/*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 10
          }
        }
      },
      "correctness": {
        "noUnusedVariables": {
          "level": "error",
          "fix": "unsafe",
          "options": {
            "ignoreRestSiblings": true
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/pages/**/*.vue", "**/components/**/*.vue"],
      "linter": {
        "rules": {
          "style": {
            "useVueMultiWordComponentNames": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["**/core/src/domain/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "zod",
                      "dexie",
                      "vue",
                      "hookable",
                      "decimal.js",
                      "rrule",
                      "date-fns",
                      "uuid",
                      "fake-indexeddb",
                      "@meu-caderno/*",
                      "../engine",
                      "../engine/*",
                      "../application",
                      "../application/*"
                    ],
                    "message": "domain deve ser puro: sem libs de impl, sem depender de engine/application"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["**/core/src/engine/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "zod",
                      "dexie",
                      "vue",
                      "hookable",
                      "@meu-caderno/adapter-*",
                      "@meu-caderno/validation",
                      "../application",
                      "../application/*"
                    ],
                    "message": "engine não depende de application nem de persistência/UI"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "**/core/src/**",
        "!**/core/src/domain/**",
        "!**/core/src/engine/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@meu-caderno/adapter-*",
                      "@meu-caderno/validation",
                      "vue",
                      "dexie"
                    ],
                    "message": "core não depende de adapters/validation/UI"
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
